{
  "name": "@mymeet/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for MyMeet.ai — connect your AI assistant to your meetings",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mymeet-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js --http",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "mymeet",
    "meetings",
    "transcription",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MyMeetAI/mymeet-mcp-server"
  }
}
