# Get your API key at https://app.mymeet.ai/settings
MYMEET_API_KEY=your-api-key-here

# Optional: hide mymeet_search_meetings from MCP clients.
# MYMEET_ENABLE_SEARCH_TOOL=false

# ── Remote OAuth (optional) ──────────────────────────────────────────────────
# Set BOTH to accept OAuth JWT access tokens (e.g. ChatGPT) alongside api keys.
# Leave unset to keep api-key-only mode.
# MYMEET_OAUTH_ISSUER=https://YOUR_TENANT.us.auth0.com/
# MYMEET_OAUTH_AUDIENCE=https://mcp.mymeet.ai/mcp
# Shared secret the backend trusts for OAuth-authenticated calls (sent as X-Service-Secret).
# MYMEET_SERVICE_SECRET=
